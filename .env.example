# ──────────────────────────────────────────────────────────────────────────
# Aqsha environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# ──────────────────────────────────────────────────────────────────────────

# ── Database (Neon) ────────────────────────────────────────────────────────
# Pooled connection string — used by the app at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/aqsha?sslmode=require"
# Direct (non-pooled) connection — used by Prisma Migrate.
# On Neon, this is the same host with `-pooler` removed from the subdomain.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/aqsha?sslmode=require"

# ── Clerk authentication ───────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# Clerk routing (defaults below match this app's folder structure)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
